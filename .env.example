# Copy to .env.local for local development, and set the same values
# in the Vercel project dashboard for production.

# Required: your Resend API key (server-only, NEVER expose to client).
# Create one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Public: base URL used to build download links in outbound emails.
# Leave as the Vercel-assigned URL in preview, or set your custom domain in production.
NEXT_PUBLIC_PRODUCTION_URL=https://brief.mmc.us
